generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  avatar         String    @default("/avatar-default.svg")
  role           String    @default("user")
  xp             Int       @default(0)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  dailyGoal      Int       @default(50)
  joinedAt       DateTime  @default(now())
  lastActiveDate DateTime?
  learnedKana    Int       @default(0)
  learnedKanji   Int       @default(0)
  learnedWords   Int       @default(0)
  recentLessons  Json?

  activityLogs      ActivityLog[]
  leagueParticipant LeagueParticipant?
  achievements      UserAchievement[]
  lessonProgress    UserLessonProgress[]
  testAttempts      TestAttempt[]
}

model ActivityLog {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  xpGained     Int      @default(0)
  minutesSpent Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model League {
  id           String              @id @default(uuid())
  name         String              @unique
  order        Int                 @unique
  participants LeagueParticipant[]
}

model LeagueParticipant {
  id       String @id @default(uuid())
  userId   String @unique
  leagueId String
  weeklyXp Int    @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id])
}

model Achievement {
  id          String @id @default(uuid())
  title       String
  description String
  icon        String
  maxProgress Int
  sortOrder   Int    @default(0)

  users UserAchievement[]
}

model UserAchievement {
  id            String    @id @default(uuid())
  userId        String
  achievementId String
  progress      Int       @default(0)
  unlockedAt    DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model KanaGroup {
  id        String @id
  type      String
  name      String
  nameJp    String
  sortOrder Int    @default(0)

  chars KanaChar[]
}

model KanaChar {
  id          String  @id
  groupId     String
  char        String
  romaji      String
  type        String
  groupCode   String
  examples    Json
  learned     Boolean @default(false)
  strokeOrder Json?
  sortOrder   Int     @default(0)

  group KanaGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Vocabulary {
  id           String @id @default(uuid())
  word         String
  reading      String
  meaning      String
  partOfSpeech String
  jlptLevel    String
  examples     Json
  tags         Json
  sortOrder    Int    @default(0)
}

model Kanji {
  id          String  @id @default(uuid())
  char        String  @unique
  meaning     String
  onyomi      Json
  kunyomi     Json
  jlptLevel   String
  strokeCount Int
  examples    Json
  radical     String
  learned     Boolean @default(false)
  sortOrder   Int     @default(0)
}

model Lesson {
  id            String @id @default(uuid())
  title         String
  description   String
  type          String
  difficulty    String
  xpReward      Int
  estimatedTime Int
  sortOrder     Int    @default(0)

  questions TestQuestion[]
  progress  UserLessonProgress[]
  attempts  TestAttempt[]
}

model TestQuestion {
  id            String  @id @default(uuid())
  lessonId      String
  type          String
  question      String
  options       Json?
  correctAnswer String
  hint          String?
  explanation   String?
  sortOrder     Int     @default(0)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model UserLessonProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  progress     Int       @default(0)
  lastAccessed DateTime  @default(now())
  xpEarned     Int       @default(0)
  completedAt  DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model TestAttempt {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  score          Int
  totalQuestions Int
  correctAnswers Int
  timeSpent      Int
  completedAt    DateTime
  answers        Json?
  xpAwarded      Int      @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([lessonId])
}

model PracticeSession {
  id             String @id
  type           String
  title          String
  description    String
  icon           String
  itemCount      Int
  completedCount Int
  accuracy       Int
  sortOrder      Int    @default(0)
}
